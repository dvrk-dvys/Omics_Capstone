# ============================================================
# Omics Capstone .gitignore
# ============================================================

# ----- macOS -----
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ----- IDE -----
.idea/
.vscode/
*.iml

# ----- Claude Code / Anthropic -----
.claude/
.anthropic/
CLAUDE.md
.claude_files/
claude_output*/
claude_cache*/

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.env
.venv/
venv/
.pytest_cache/
.mypy_cache/

# ----- Jupyter -----
.ipynb_checkpoints/
*.ipynb

# ----- R -----
.Rhistory
.RData
.Rproj.user/
*.Rproj
.Renviron

# ----- AutoOmics_ML_Pipeline app -----
# GEO source copies (large, re-copyable from data/femoral_head_necrosis/)
AutoOmics_ML_Pipeline/app/data/GSE123568_series_matrix.txt.gz
AutoOmics_ML_Pipeline/app/data/GSE123568_family.soft.gz
# App pipeline outputs (generated — do not commit)
AutoOmics_ML_Pipeline/app/data/parsed/
AutoOmics_ML_Pipeline/app/data/feature_selection/
AutoOmics_ML_Pipeline/app/data/models/
AutoOmics_ML_Pipeline/app/data/plots/
AutoOmics_ML_Pipeline/app/data/biomarker_shortlist.csv
# MLflow tracking
AutoOmics_ML_Pipeline/mlruns/
AutoOmics_ML_Pipeline/mlartifacts/
AutoOmics_ML_Pipeline/mlflow.db
AutoOmics_ML_Pipeline/app/mlflow.db

# ----- Large / Generated Data Files -----
# Split output directories (29k five files — never commit these)
data/split_output_*/
split_output_*/

# Large generated matrices (regenerate from source)
preprocessed_matrix.csv
pseudobulk_matrix.csv

# Parsed/intermediate matrices (regenerate by running parse_series_matrix.py + preprocess.py)
data/femoral_head_necrosis/parsed_old/parsed_matrix.csv
data/femoral_head_necrosis/parsed_old/preprocessed_matrix.csv

# Raw GEO data downloads (large, re-downloadable from GEO — do not commit)
data/femoral_head_necrosis/GSE123568_series_matrix.txt.gz
data/femoral_head_necrosis/GSE123568_family.soft.gz

# Raw genomics downloads (large, re-downloadable)
data/GSE*_raw/
data/soulaan_prostate_cancer/
data/femoral_head_necrosis_old/

# Large screenshots (not essential for reproducibility)
data/screenshots/Screenshot*.png

# Generic large genomics file types
*.gz
*.tar
*.bam
*.bai
*.vcf
*.vcf.gz
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.sam
*.bed
*.bigwig
*.bw
*.h5
*.hdf5

# ----- Logs & Temp -----
*.log
*.tmp
*.temp
*.swp
*.swo
*~
